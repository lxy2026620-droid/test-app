/* eslint-disable func-names */
// 文本中间省略
(function () {
  const sep = '...';
  // 获取容器宽度
  function getContainerWidth(middleEllipsisEl) {
    if (!middleEllipsisEl) {
      return 0;
    }
    const { parentElement } = middleEllipsisEl;
    const parentComputedStyle = window.getComputedStyle(parentElement);
    const parentPaddingLeft = parseInt(parentComputedStyle.paddingLeft, 10);
    const parentPaddingRight = parseInt(parentComputedStyle.paddingRight, 10);
    const parentWidth = parseInt(parentComputedStyle.width, 10);
    const { boxSizing } = parentComputedStyle;
    if (parentWidth) {
      return boxSizing === 'border-box'
        ? parentWidth - parentPaddingLeft - parentPaddingRight
        : parentWidth;
    }
    return 0;
  }

  // 创建测量元素
  function createMeasureElement(middleEllipsisEl) {
    const style = window.getComputedStyle(middleEllipsisEl);
    const measure = document.createElement('span');
    measure.style.visibility = 'hidden';
    measure.style.whiteSpace = 'nowrap';
    measure.style.position = 'absolute';
    measure.style.font = style.font;
    return measure;
  }

  // 拼接省略
  function getEllipsisText(leftText, rightText) {
    return `${leftText}${sep}${rightText}`;
  }

  function getOneLineTextWithEllipsis(middleEllipsisEl, text) {
    const containerWidth = getContainerWidth(middleEllipsisEl);
    if (containerWidth === 0) {
      return '';
    }

    const measure = createMeasureElement(middleEllipsisEl);
    document.body.appendChild(measure);
    measure.textContent = text;

    if (measure.offsetWidth <= containerWidth) {
      middleEllipsisEl.textContent = text;
      document.body.removeChild(measure);
      return text;
    }

    let leftText = '';
    let rightText = '';
    let resultText = '';
    const totalLen = text.length;

    for (let i = 1; i < totalLen; i++) {
      leftText = text.slice(0, i);
      rightText = text.slice(totalLen - i);
      resultText = getEllipsisText(leftText, rightText);
      measure.textContent = resultText;
      if (measure.offsetWidth > containerWidth) {
        leftText = text.slice(0, i - 1);
        rightText = text.slice(totalLen - (i - 1));
        resultText = getEllipsisText(leftText, rightText);
        break;
      }
    }
    document.body.removeChild(measure);

    return resultText;
  }

  // 单行省略逻辑
  function renderSingleLineMiddleEllipsis(middleEllipsisEl) {
    const text = middleEllipsisEl.getAttribute('data-text');
    if (!text) {
      return;
    }
    const resultText = getOneLineTextWithEllipsis(middleEllipsisEl, text);
    middleEllipsisEl.textContent = resultText || '';
  }

  const middleEllipsisElList = document.querySelectorAll('.js-middle-ellipsis');
  middleEllipsisElList.forEach((middleEllipsisEl) => {
    renderSingleLineMiddleEllipsis(middleEllipsisEl);
  });
}());
</script>
