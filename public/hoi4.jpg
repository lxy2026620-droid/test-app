(function () {
  const ua = navigator.userAgent;
  function isMobile() {
    return /(phone|pad|pod|iPhone|iPod|ios|iPad|Android|Mobile|BlackBerry|IEMobile|MQQBrowser|JUC|Fennec|wOSBrowser|BrowserNG|WebOS|Symbian|Windows Phone)/i.test(ua,);
  }
  function isAndroid() {
    return /android/i.test(ua);
  }
  function isIos() {
    return /(phone|pad|pod|iPhone|iPod|ios|iPad)/i.test(ua);
  }
  // 是否为 鸿蒙
  function isHarmony() {
    return /OpenHarmony/i.test(ua);
  }
  function isLinux() {
    if (isAndroid()) {
      return false;
    }
    return /linux/i.test(ua);
  }

  function initPlatform() {
    if (isMobile()) {
      document.body.setAttribute('is-mobile', '');
      if (isAndroid()) {
        document.body.setAttribute('is-android', '');
      } else if (isIos()) {
        document.body.setAttribute('is-ios', '');
      }
    } else {
      document.body.setAttribute('is-pc', '');
      if (isLinux()) {
        document.body.setAttribute('is-linux', '');
      }
    }
    if (isHarmony()) {
      document.body.setAttribute('is-harmony', '');
    }
  }
  initPlatform();
}());
